<ResourceDictionary x:Class="GearTrayUI.TrayResources"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:tb="http://www.hardcodet.net/taskbar"
                    xmlns:local="clr-namespace:GearTrayUI">

    <!-- Value Converters for Dynamic UI Layout -->
    <local:BatteryVisibilityConverter x:Key="BatteryVisibilityConverter"/>
    <local:DoubleToBoolConverter x:Key="DoubleToBoolConverter"/>
    <local:ControlTypeVisibilityConverter x:Key="ControlTypeVisibilityConverter"/>
    <local:PowerStatusConverter x:Key="PowerStatusConverter"/>

    <!-- TaskbarIcon Resource -->
    <tb:TaskbarIcon x:Key="NotifyIcon"
                    IconSource="pack://application:,,,/logo_black.ico"
                    ToolTipText="GearTray Manager">
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu Background="#1C1C1C" BorderBrush="#3C3C3C" BorderThickness="1" Width="280">
                <ContextMenu.Resources>
                    <Style TargetType="MenuItem">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="12,6"/>
                    </Style>
                    <CollectionViewSource x:Key="GroupedPeripherals" Source="{Binding Source={x:Static local:App.Coordinator}, Path=ActiveDevices}">
                        <CollectionViewSource.GroupDescriptions>
                            <PropertyGroupDescription PropertyName="Category"/>
                        </CollectionViewSource.GroupDescriptions>
                    </CollectionViewSource>
                </ContextMenu.Resources>
                
                <MenuItem Header="Open Settings" Click="OpenSettings_Click"/>
                <Separator Background="#3C3C3C" Margin="0,4"/>
                
                <!-- Active Peripherals Card Container -->
                <MenuItem IsEnabled="True" Background="Transparent" StaysOpenOnClick="True">
                    <MenuItem.Header>
                        <StackPanel Width="240" Margin="0,6">
                            <TextBlock Text="Active Peripherals" Foreground="#A0A0A0" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="11"/>
                            
                            <!-- List of Peripherals -->
                            <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedPeripherals}}">
                                <ItemsControl.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.ContainerStyle>
                                            <Style TargetType="{x:Type GroupItem}">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                                            <Expander IsExpanded="True" BorderThickness="0" Background="Transparent" Margin="0,6">
                                                                <Expander.Header>
                                                                    <TextBlock Text="{Binding Name}" Foreground="#A0A0A0" FontWeight="SemiBold" FontSize="11" Margin="4,2"/>
                                                                </Expander.Header>
                                                                <ItemsPresenter />
                                                            </Expander>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </GroupStyle.ContainerStyle>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#242424" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="6" Margin="0,4" Padding="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                
                                                <!-- Row 1: Icon/Type representation & Device Name & Online status -->
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <!-- Bullet point / status dot indicator -->
                                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                                            <Ellipse.Style>
                                                                <Style TargetType="Ellipse">
                                                                     <Setter Property="Fill" Value="#D9534F"/>
                                                                     <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                            <Setter Property="Fill" Value="#5CB85C"/>
                                                                        </DataTrigger>
                                                                     </Style.Triggers>
                                                                </Style>
                                                            </Ellipse.Style>
                                                        </Ellipse>
                                                        
                                                        <TextBlock Text="{Binding DisplayName}" Foreground="White" FontWeight="Medium" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="150"/>
                                                    </StackPanel>
                                                    
                                                    <TextBlock Grid.Column="1" Text="{Binding Power, Converter={StaticResource PowerStatusConverter}}" Foreground="#007ACC" FontWeight="Bold" FontSize="9" VerticalAlignment="Center"/>
                                                </Grid>
                                                
                                                <!-- Row 2: Battery Bar (if device reports battery level) -->
                                                <Grid Grid.Row="1" Margin="0,8,0,0" Visibility="{Binding BatteryPercentage, Converter={StaticResource BatteryVisibilityConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <ProgressBar Value="{Binding BatteryPercentage}" Maximum="100" Height="6" Background="#141414" BorderThickness="0" VerticalAlignment="Center">
                                                        <ProgressBar.Foreground>
                                                            <SolidColorBrush Color="#007ACC"/>
                                                        </ProgressBar.Foreground>
                                                    </ProgressBar>
                                                    
                                                    <TextBlock Grid.Column="1" Text="{Binding BatteryPercentage, StringFormat={}{0}%}" Foreground="#A0A0A0" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                </Grid>
                                                
                                                <!-- Row 3: Dynamic Device Controls -->
                                                <ItemsControl Grid.Row="2" ItemsSource="{Binding Controls}" Margin="0,8,0,0" Visibility="{Binding Controls.Count, Converter={StaticResource BatteryVisibilityConverter}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,4">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="70"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                
                                                                <TextBlock Text="{Binding DisplayName}" Foreground="#A0A0A0" FontSize="11" VerticalAlignment="Center"/>
                                                                
                                                                <!-- Toggle Button View -->
                                                                <CheckBox Grid.Column="1" IsChecked="{Binding Value, Converter={StaticResource DoubleToBoolConverter}}"
                                                                          Visibility="{Binding ControlType, Converter={StaticResource ControlTypeVisibilityConverter}, ConverterParameter=Toggle}"
                                                                          Checked="Control_Changed" Unchecked="Control_Changed" VerticalAlignment="Center"/>
                                                                
                                                                <!-- Slider Control View -->
                                                                <Slider Grid.Column="1" Value="{Binding Value}" Minimum="0" Maximum="100" Height="20"
                                                                        Visibility="{Binding ControlType, Converter={StaticResource ControlTypeVisibilityConverter}, ConverterParameter=Slider}"
                                                                        ValueChanged="Slider_ValueChanged" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </MenuItem.Header>
                </MenuItem>
                
                <Separator Background="#3C3C3C" Margin="0,4"/>
                <MenuItem Header="Exit" Click="Exit_Click"/>
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>

</ResourceDictionary>
