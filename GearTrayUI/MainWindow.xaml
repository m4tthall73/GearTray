<Window x:Class="GearTrayUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:local="clr-namespace:GearTrayUI"
        Title="GearTray" Height="600" Width="1000" MinWidth="1000" MinHeight="600"
        Icon="pack://application:,,,/logo_black.ico"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid>
        <!-- System Tray Icon declared inline inside the active visual tree -->
        <tb:TaskbarIcon x:Name="NotifyIcon"
                        IconSource="pack://application:,,,/logo_black.ico"
                        ToolTipText="">
            <tb:TaskbarIcon.TrayToolTip>
                <ToolTip Background="Transparent" BorderThickness="0" Padding="0">
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="8,4">
                        <TextBlock Text="GearTray Manager" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="Medium"/>
                    </Border>
                </ToolTip>
            </tb:TaskbarIcon.TrayToolTip>
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" Width="340">
                    <ContextMenu.Template>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    Padding="0,4">
                                <ItemsPresenter />
                            </Border>
                        </ControlTemplate>
                    </ContextMenu.Template>
                    <ContextMenu.Resources>
                        <Style TargetType="MenuItem">
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="12,6"/>
                        </Style>
                        <CollectionViewSource x:Key="GroupedPeripherals" Source="{Binding Source={x:Static local:App.Coordinator}, Path=ActiveDevices}">
                            <CollectionViewSource.GroupDescriptions>
                                <PropertyGroupDescription PropertyName="Category"/>
                            </CollectionViewSource.GroupDescriptions>
                        </CollectionViewSource>
                    </ContextMenu.Resources>
                    
                    <MenuItem Header="Open Settings" Click="OpenSettings_Click"/>
                    <Separator Background="{DynamicResource BorderBrushSoft}" Margin="0,4"/>
                    
                    <!-- Active Peripherals Card Container -->
                    <MenuItem IsEnabled="True" Background="Transparent" StaysOpenOnClick="True">
                        <MenuItem.Template>
                            <ControlTemplate TargetType="MenuItem">
                                <ContentPresenter Content="{TemplateBinding Header}"/>
                            </ControlTemplate>
                        </MenuItem.Template>
                        <MenuItem.Header>
                            <StackPanel Width="316" Margin="12,6">
                                <TextBlock Text="Active Peripherals" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" Margin="0,0,0,8" FontSize="11"/>
                                
                                <!-- List of Peripherals -->
                                <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedPeripherals}}">
                                    <ItemsControl.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.ContainerStyle>
                                                <Style TargetType="{x:Type GroupItem}">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                                                <Expander IsExpanded="True" BorderThickness="0" Background="Transparent" Margin="0,6">
                                                                    <Expander.Header>
                                                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource MutedTextBrush}" FontWeight="SemiBold" FontSize="11" Margin="4,2"/>
                                                                    </Expander.Header>
                                                                    <ItemsPresenter />
                                                                </Expander>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </GroupStyle.ContainerStyle>
                                        </GroupStyle>
                                    </ItemsControl.GroupStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Margin="0,4" Padding="10">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    
                                                    <!-- Row 1: Icon/Type representation & Device Name & Online status -->
                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <!-- Bullet point / status dot indicator -->
                                                            <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                         <Setter Property="Fill" Value="#D9534F"/>
                                                                         <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                                <Setter Property="Fill" Value="#5CB85C"/>
                                                                            </DataTrigger>
                                                                         </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>
                                                            
                                                            <!-- Vector icon representing the peripheral type -->
                                                            <Path Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"
                                                                  Data="{Binding Converter={StaticResource DeviceTypeToIconConverter}}">
                                                                <Path.Style>
                                                                    <Style TargetType="Path">
                                                                        <Setter Property="Fill" Value="{DynamicResource MutedTextBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                                <Setter Property="Fill" Value="#5CB85C"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Path.Style>
                                                            </Path>
                                                            
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextBrush}" FontWeight="Medium" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="210"/>
                                                        </StackPanel>
                                                        
                                                        <TextBlock Grid.Column="1" Text="{Binding Power, Converter={StaticResource PowerStatusConverter}}" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="9" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    
                                                    <!-- Row 2: Battery Bar (if device reports battery level) -->
                                                    <Grid Grid.Row="1" Margin="0,8,0,0" Visibility="{Binding BatteryPercentage, Converter={StaticResource BatteryVisibilityConverter}}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <ProgressBar Value="{Binding BatteryPercentage, Mode=OneWay}" Maximum="100" Height="6" Background="{DynamicResource SurfaceBrush}" BorderThickness="0" VerticalAlignment="Center">
                                                            <ProgressBar.Foreground>
                                                                <SolidColorBrush Color="#007ACC"/>
                                                            </ProgressBar.Foreground>
                                                        </ProgressBar>
                                                        
                                                        <TextBlock Grid.Column="1" Text="{Binding BatteryPercentage, StringFormat={}{0}%}" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </Grid>
                                                    
                                                    <!-- Row 3: Dynamic Device Controls -->
                                                    <ItemsControl Grid.Row="2" ItemsSource="{Binding Controls}" Margin="0,8,0,0" Visibility="{Binding Controls.Count, Converter={StaticResource BatteryVisibilityConverter}}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="70"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ControlType}" Value="Action">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    
                                                                    <!-- Toggle Button View -->
                                                                    <CheckBox Grid.Column="1" IsChecked="{Binding Value, Converter={StaticResource DoubleToBoolConverter}, Mode=OneWay}"
                                                                              Visibility="{Binding ControlType, Converter={StaticResource ControlTypeVisibilityConverter}, ConverterParameter=Toggle}"
                                                                              Checked="Control_Changed" Unchecked="Control_Changed" VerticalAlignment="Center"/>
                                                                    
                                                                    <!-- Slider Control View -->
                                                                    <Slider Grid.Column="1" Value="{Binding Value, Mode=OneWay}" Minimum="0" Maximum="100" Height="20"
                                                                            Visibility="{Binding ControlType, Converter={StaticResource ControlTypeVisibilityConverter}, ConverterParameter=Slider}"
                                                                            ValueChanged="Slider_ValueChanged"
                                                                            PreviewMouseLeftButtonUp="Slider_MouseUp"
                                                                            VerticalAlignment="Center"/>
 
                                                                    <!-- Action Button View -->
                                                                    <Button Grid.Column="0" Grid.ColumnSpan="2" Content="{Binding DisplayName}" Click="Button_Click"
                                                                            Visibility="{Binding ControlType, Converter={StaticResource ControlTypeVisibilityConverter}, ConverterParameter=Action}"
                                                                            Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Padding="8,4" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    
                    <Separator Background="{DynamicResource BorderBrushSoft}" Margin="0,4"/>
                    <MenuItem Header="Exit" Click="Exit_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="GearTray Settings" FontSize="24" Foreground="{DynamicResource TextBrush}" FontWeight="Bold"/>
                    <TextBlock Text="A pluggable desktop hardware controller center" FontSize="11" Foreground="{DynamicResource MutedTextBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Left-tabbed Sidebar Tab Control -->
            <TabControl Grid.Row="1" TabStripPlacement="Left" Background="Transparent" BorderThickness="0" BorderBrush="Transparent">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="HeaderTemplate">
                            <Setter.Value>
                                <DataTemplate>
                                    <ContentPresenter Content="{TemplateBinding Content}" Margin="16,10"/>
                                </DataTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="Border" CornerRadius="6" Background="Transparent" Margin="0,4,16,4" Width="140" SnapsToDevicePixels="true">
                                        <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Left" ContentSource="Header" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- General Tab -->
                <TabItem Header="General">
                    <Grid Margin="0,8,0,0">
                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="20" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="General Settings" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,16"/>
                                <CheckBox x:Name="ShowOfflineCheckbox" Content="Show offline peripherals in tray menu" 
                                          Foreground="{DynamicResource TextBrush}" FontSize="13"
                                          Checked="ShowOffline_Changed" Unchecked="ShowOffline_Changed"/>
                                
                                <CheckBox x:Name="AutoSwitchCheckbox" Content="Automatically switch to headphones when connected" 
                                          Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,16,0,0"
                                          Checked="AutoSwitch_Changed" Unchecked="AutoSwitch_Changed"/>

                                <CheckBox x:Name="PauseFullScreenCheckbox" Content="Pause battery notifications for full screen apps" 
                                          Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,16,0,0"
                                          Checked="PauseFullScreen_Changed" Unchecked="PauseFullScreen_Changed"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Alerts Tab -->
                <TabItem Header="Alerts">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                        <StackPanel Margin="0,0,16,0">
                            <!-- Card 1: Default alert settings -->
                            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Default Alert Settings" Foreground="{DynamicResource TextBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="Default low-battery threshold" Foreground="{DynamicResource MutedTextBrush}" FontSize="12" Margin="0,0,0,12"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Slider x:Name="GlobalThresholdSlider" Minimum="5" Maximum="50" TickFrequency="5" IsSnapToTickEnabled="True" 
                                                Value="{Binding Source={x:Static local:App.Coordinator}, Path=GlobalBatteryThreshold}" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Background="{DynamicResource BorderBrushSoft}" CornerRadius="4" Padding="8,4" Margin="12,0,0,0">
                                            <TextBlock Text="{Binding ElementName=GlobalThresholdSlider, Path=Value, StringFormat={}{0}%}" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                    
                                    <Button Content="Test Alert" Click="TestAlert_Click" Padding="16,6" Margin="0,16,0,0" HorizontalAlignment="Left"
                                            Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" FontSize="12" FontWeight="SemiBold">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="4"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Border>
 
                            <!-- Section Header for Overrides -->
                            <TextBlock Text="Active Overridden Alert Settings" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="Bold" Margin="0,8,0,12"/>
 
                            <!-- Card 2: Low battery thresholds per device (Only for items in OverriddenDevicesView) -->
                            <ItemsControl ItemsSource="{Binding OverriddenDevicesView}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                                            <StackPanel>
                                                <!-- Device Title / Custom Name with Type Icon -->
                                                <Grid Margin="0,0,0,16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"
                                                          Data="{Binding Converter={StaticResource DeviceTypeToIconConverter}}">
                                                        <Path.Style>
                                                            <Style TargetType="Path">
                                                                <Setter Property="Fill" Value="{DynamicResource MutedTextBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                        <Setter Property="Fill" Value="#5CB85C"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Path.Style>
                                                    </Path>
                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="{DynamicResource TextBrush}" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </Grid>
                                                
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="24"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Left Column: Custom Name Input -->
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Custom device name" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                        <TextBlock Text="Leave blank to use the device's original name." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,8"/>
                                                        <TextBox Text="{Binding CustomName, UpdateSourceTrigger=PropertyChanged}" Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" Padding="8,6" FontSize="12" Height="32" VerticalContentAlignment="Center"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Right Column: Threshold Slider -->
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Low-battery alert threshold" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                        
                                                        <CheckBox Content="Use default threshold" IsChecked="{Binding UseDefaultThreshold}" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,4,0,12"/>
                                                        
                                                        <Grid IsEnabled="{Binding IsSliderEnabled}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Slider Minimum="5" Maximum="50" TickFrequency="5" IsSnapToTickEnabled="True" 
                                                                    Value="{Binding Threshold, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                            <Border Grid.Column="1" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="8,4" Margin="12,0,0,0" MinWidth="40" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding Threshold, StringFormat={}{0}%}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <!-- Dynamic Details Grid -->
                                                <Grid Margin="0,16,0,16">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <Border Grid.Column="0" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="8,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Battery: " Foreground="{DynamicResource MutedTextBrush}" FontSize="11"/>
                                                            <TextBlock Text="{Binding BatteryPercentageText}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    
                                                    <Border Grid.Column="2" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="8,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Last updated: " Foreground="{DynamicResource MutedTextBrush}" FontSize="11"/>
                                                            <TextBlock Text="{Binding LastUpdatedText}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
  
                                                    <Border Grid.Column="4" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="8,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Alert Status: " Foreground="{DynamicResource MutedTextBrush}" FontSize="11"/>
                                                            <TextBlock Text="{Binding PauseStatusText}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                                
                                                <!-- Action Buttons Bar -->
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="Pause for 1 hour" Command="{Binding Pause1HourCommand}" Padding="12,6" Margin="0,0,8,0"
                                                            Background="{DynamicResource BorderBrushSoft}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" FontSize="11" FontWeight="SemiBold">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                    
                                                    <Button Content="Pause until next launch" Command="{Binding PauseUntilLaunchCommand}" Padding="12,6" Margin="0,0,8,0"
                                                            Background="{DynamicResource BorderBrushSoft}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" FontSize="11" FontWeight="SemiBold">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                    
                                                    <Button Content="Resume alerts" Command="{Binding ResumeAlertsCommand}" Padding="12,6"
                                                            Background="{DynamicResource BorderBrushSoft}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" FontSize="11" FontWeight="SemiBold">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Devices Tab -->
                <TabItem Header="Devices">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Discovered Devices" Foreground="{DynamicResource TextBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                        <ListBox Grid.Row="1" ItemsSource="{Binding DevicesList}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto" HorizontalContentAlignment="Stretch">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Focusable" Value="True"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="ListBoxItem_PreviewMouseLeftButtonDown"/>
                                    <Style.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent" />
                                    </Style.Resources>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="DeviceCardBorder" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                        <StackPanel>
                                            <!-- Header Summary -->
                                            <Grid Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <Path Width="16" Height="16" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"
                                                      Data="{Binding Converter={StaticResource DeviceTypeToIconConverter}}">
                                                    <Path.Style>
                                                        <Style TargetType="Path">
                                                            <Setter Property="Fill" Value="{DynamicResource MutedTextBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                                                    <Setter Property="Fill" Value="#5CB85C"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Path.Style>
                                                </Path>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource TextBrush}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/>
                                                        <Border x:Name="ActiveIndicator" Background="{DynamicResource AccentBrush}" CornerRadius="3" Padding="6,2" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="Collapsed">
                                                            <TextBlock Text="Active Playback Device" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding DeviceId}" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Category}" Foreground="{DynamicResource MutedTextBrush}" FontSize="10" FontWeight="SemiBold" Margin="0,0,16,0"/>
                                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#D9534F"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                        <Setter Property="Fill" Value="#5CB85C"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                    <TextBlock FontSize="12" FontWeight="SemiBold" Width="50">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Offline"/>
                                                                <Setter Property="Foreground" Value="#D9534F"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                                        <Setter Property="Text" Value="Online"/>
                                                                        <Setter Property="Foreground" Value="#5CB85C"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Expanded Config & Controls Panel -->
                                            <StackPanel x:Name="DetailsPanel" Margin="0,16,0,0" Visibility="Collapsed">
                                                <Separator Background="{DynamicResource BorderBrushSoft}" Margin="0,0,0,16"/>
                                                
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="24"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <!-- Left: Custom Name -->
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Custom device name" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                        <TextBlock Text="Leave blank to use the device's original name." Foreground="{DynamicResource MutedTextBrush}" FontSize="11" Margin="0,0,0,8"/>
                                                        <TextBox Text="{Binding CustomName, UpdateSourceTrigger=PropertyChanged}" Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" Padding="8,6" FontSize="12" Height="32" VerticalContentAlignment="Center"/>
                                                    </StackPanel>
                                                    
                                                    <!-- Right: Battery Alert Threshold -->
                                                    <StackPanel Grid.Column="2" Visibility="{Binding HasBattery, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <TextBlock Text="Low-battery alert threshold" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                        <CheckBox Content="Use default threshold" IsChecked="{Binding UseDefaultThreshold}" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,4,0,12"/>
                                                        <Grid IsEnabled="{Binding IsSliderEnabled}">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Slider Minimum="5" Maximum="50" TickFrequency="5" IsSnapToTickEnabled="True" 
                                                                    Value="{Binding Threshold, Mode=TwoWay}" VerticalAlignment="Center"/>
                                                            <Border Grid.Column="1" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="8,4" Margin="12,0,0,0" MinWidth="40" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding Threshold, StringFormat={}{0}%}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <!-- Dynamic Details Grid -->
                                                <Grid Margin="0,16,0,16" Visibility="{Binding HasBattery, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="16"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    
                                                    <Border Grid.Column="0" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="8,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Battery: " Foreground="{DynamicResource MutedTextBrush}" FontSize="11"/>
                                                            <TextBlock Text="{Binding BatteryPercentageText}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    
                                                    <Border Grid.Column="2" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="8,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Last updated: " Foreground="{DynamicResource MutedTextBrush}" FontSize="11"/>
                                                            <TextBlock Text="{Binding LastUpdatedText}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                    
                                                    <Border Grid.Column="4" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Padding="8,4">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Alert Status: " Foreground="{DynamicResource MutedTextBrush}" FontSize="11"/>
                                                            <TextBlock Text="{Binding PauseStatusText}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                                
                                                <!-- Action Buttons Bar -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16" Visibility="{Binding HasBattery, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Button Content="Pause for 1 hour" Command="{Binding Pause1HourCommand}" Padding="12,6" Margin="0,0,8,0"
                                                            Background="{DynamicResource BorderBrushSoft}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" FontSize="11" FontWeight="SemiBold">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                    
                                                    <Button Content="Pause until next launch" Command="{Binding PauseUntilLaunchCommand}" Padding="12,6" Margin="0,0,8,0"
                                                            Background="{DynamicResource BorderBrushSoft}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" FontSize="11" FontWeight="SemiBold">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                    
                                                    <Button Content="Resume alerts" Command="{Binding ResumeAlertsCommand}" Padding="12,6"
                                                            Background="{DynamicResource BorderBrushSoft}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" FontSize="11" FontWeight="SemiBold">
                                                        <Button.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="4"/>
                                                            </Style>
                                                        </Button.Resources>
                                                    </Button>
                                                </StackPanel>

                                                <!-- Dynamic Device Controls (Sliders, Buttons, Checkboxes) -->
                                                <StackPanel Visibility="{Binding Controls.Count, Converter={StaticResource BatteryVisibilityConverter}}">
                                                    <TextBlock Text="Device Controls" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                                    <ItemsControl ItemsSource="{Binding Controls}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Margin="0,4">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="70"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    
                                                                    <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ControlType}" Value="Action">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    
                                                                    <!-- Toggle View -->
                                                                    <CheckBox Grid.Column="1" IsChecked="{Binding Value, Converter={StaticResource DoubleToBoolConverter}, Mode=OneWay}"
                                                                              Visibility="{Binding ControlType, Converter={StaticResource ControlTypeVisibilityConverter}, ConverterParameter=Toggle}"
                                                                              Checked="Control_Changed" Unchecked="Control_Changed" VerticalAlignment="Center"/>
                                                                    
                                                                    <!-- Slider View -->
                                                                    <Slider Grid.Column="1" Value="{Binding Value, Mode=OneWay}" Minimum="0" Maximum="100" Height="20"
                                                                            Visibility="{Binding ControlType, Converter={StaticResource ControlTypeVisibilityConverter}, ConverterParameter=Slider}"
                                                                            ValueChanged="Slider_ValueChanged"
                                                                            PreviewMouseLeftButtonUp="Slider_MouseUp"
                                                                            VerticalAlignment="Center"/>
                                                                    
                                                                    <!-- Action Button View -->
                                                                    <Button Grid.Column="0" Grid.ColumnSpan="2" Content="{Binding DisplayName}" Click="Button_Click"
                                                                            Visibility="{Binding ControlType, Converter={StaticResource ControlTypeVisibilityConverter}, ConverterParameter=Action}"
                                                                            Background="{DynamicResource AccentBrush}" Foreground="White" BorderThickness="0" Padding="8,4" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Stretch"/>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Path=IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                            <Setter TargetName="DetailsPanel" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsDefault}" Value="True">
                                            <Setter TargetName="DeviceCardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter TargetName="DeviceCardBorder" Property="BorderThickness" Value="2"/>
                                            <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </TabItem>

                <!-- Diagnostics Tab -->
                <TabItem Header="Diagnostics">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Toggle & Action Bar -->
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox x:Name="EventsLoggingCheckbox" Content="Enable Events Logging" IsChecked="True"
                                      Foreground="{DynamicResource TextBrush}" FontSize="13" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ComboBox x:Name="LogFilterComboBox" SelectionChanged="LogFilter_SelectionChanged" Width="100" Margin="0,0,12,0" Background="{DynamicResource SurfaceBrush}" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" VerticalContentAlignment="Center">
                                    <ComboBox.Resources>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBox">
                                                        <Grid>
                                                            <ToggleButton x:Name="ToggleButton" 
                                                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                                                          Background="{TemplateBinding Background}" 
                                                                          Foreground="{TemplateBinding Foreground}" 
                                                                          Grid.Column="2" 
                                                                          Focusable="false"
                                                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                                                          ClickMode="Press">
                                                                <ToggleButton.Template>
                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,4">
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <ContentPresenter Grid.Column="0" Content="{TemplateBinding Content}" VerticalAlignment="Center" Margin="2,0,8,0"/>
                                                                                <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0 Z" Fill="{DynamicResource TextBrush}" Width="8" Height="4" Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                                            </Grid>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </ToggleButton.Template>
                                                            </ToggleButton>
                                                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="8,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                                                    <Border x:Name="DropDownBorder" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="4" Margin="0,2,0,0">
                                                                        <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                                                        </ScrollViewer>
                                                                    </Border>
                                                                </Grid>
                                                            </Popup>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                        
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                            <Setter Property="Padding" Value="8,4"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <Border x:Name="Gd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="2">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="true">
                                                                 <Setter TargetName="Gd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                 <Setter Property="Foreground" Value="White"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="true">
                                                                 <Setter TargetName="Gd" Property="Background" Value="{DynamicResource WindowBackgroundBrush}"/>
                                                                 <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ComboBox.Resources>
                                    <ComboBoxItem Content="All" IsSelected="True"/>
                                    <ComboBoxItem Content="Audio"/>
                                    <ComboBoxItem Content="Logitech"/>
                                    <ComboBoxItem Content="System"/>
                                </ComboBox>
                                <Button Content="Copy Log" Click="CopyLog_Click" Padding="12,4" Margin="0,0,8,0"
                                        Background="{DynamicResource BorderBrushSoft}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" FontSize="11" FontWeight="SemiBold">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                                <Button Content="Clear Log" Click="ClearLog_Click" Padding="12,4"
                                        Background="{DynamicResource BorderBrushSoft}" Foreground="{DynamicResource TextBrush}" BorderThickness="0" FontSize="11" FontWeight="SemiBold">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="4"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Logs Console Box -->
                        <Border Grid.Row="1" Background="{DynamicResource WindowBackgroundBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="6" Padding="8">
                            <ListBox x:Name="EventsListBox" ItemsSource="{Binding EventsLog}"
                                     Background="Transparent" BorderThickness="0" Padding="0"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     HorizontalContentAlignment="Stretch">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="4,2"/>
                                        <Setter Property="IsHitTestVisible" Value="True"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Time -->
                                            <TextBlock Text="{Binding Timestamp, StringFormat=[{0}]}" Foreground="{DynamicResource MutedTextBrush}" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            
                                            <!-- Category Badge -->
                                            <Border Grid.Column="1" Background="{Binding CategoryColor}" CornerRadius="3" Padding="6,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Category}" Foreground="White" FontSize="9" FontWeight="Bold" FontFamily="Segoe UI"/>
                                            </Border>
                                            
                                            <!-- Message -->
                                            <TextBlock Grid.Column="2" Text="{Binding Message}" Foreground="{DynamicResource TextBrush}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
